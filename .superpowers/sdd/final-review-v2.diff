++  writeFileSync(hooksPath, filled, 'utf-8');
++
++  const configPath = join(codexDir, 'config.toml');
++  if (existsSync(configPath)) {
++    const config = readFileSync(configPath, 'utf-8');
++    if (!config.includes('[features]')) {
