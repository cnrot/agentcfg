{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node __COMMIT_SCRIPT__ --dir __CONFIG_DIR__ --source pre_tool --tool Bash",
            "statusMessage": "agentcfg: 检测配置文件变更"
          }
        ]
      }
    ]
  }
}
