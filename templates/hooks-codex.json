{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "__COMMIT_SCRIPT__ --dir __CONFIG_DIR__ --source pre_tool --tool Bash",
            "statusMessage": "agentcfg: snapshotting"
          }
        ]
      },
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "__COMMIT_SCRIPT__ --dir __CONFIG_DIR__ --source pre_tool --tool Edit",
            "statusMessage": "agentcfg: snapshotting"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "__COMMIT_SCRIPT__ --dir __CONFIG_DIR__ --source pre_tool --tool Write",
            "statusMessage": "agentcfg: snapshotting"
          }
        ]
      },
      {
        "matcher": "MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "__COMMIT_SCRIPT__ --dir __CONFIG_DIR__ --source pre_tool --tool MultiEdit",
            "statusMessage": "agentcfg: snapshotting"
          }
        ]
      }
    ]
  }
}
