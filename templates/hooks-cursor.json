{
  "version": 1,
  "hooks": {
    "beforeShellExecution": [
      {
        "command": "node __COMMIT_SCRIPT__ --dir __CONFIG_DIR__ --source pre_shell --tool Bash"
      }
    ],
    "afterFileEdit": [
      {
        "command": "node __COMMIT_SCRIPT__ --dir __CONFIG_DIR__ --source post_edit --tool Edit"
      }
    ]
  }
}
